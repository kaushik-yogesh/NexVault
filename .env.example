# ================================================
# NexVault Environment Configuration
# ================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.

# ---- General ----
NODE_ENV=development

# ---- Server ----
PORT=5000
API_URL=http://localhost:5000

# ---- MongoDB ----
MONGODB_URI=mongodb+srv://nexvault:nexvault@ecommrceapp.xoh5mvo.mongodb.net/Nexvault

# ---- Redis ----
REDIS_URL=redis-cli --tls -u redis://default:gQAAAAAAAdmaAAIgcDI4ZDBkNjI4NGUyMDM0ZGVlYWNmZmFhODAwNmU3MTVmMw@lasting-sponge-121242.upstash.io:6379

# ---- JWT ----
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=14d

# ---- Admin ----
ADMIN_INITIAL_EMAIL=admin@nexvault.com
ADMIN_INITIAL_PASSWORD=change-this-immediately

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Sentry ----
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ---- WalletConnect ----
VITE_WALLETCONNECT_PROJECT_ID=

# ---- Indexing & Aggregators ----
VITE_ALCHEMY_API_KEY=W0x2aQOKYryPHOqv3YzR0

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---- RPC Endpoints (Optional overrides) ----
RPC_ETHEREUM_PRIMARY=https://eth.llamarpc.com
RPC_ETHEREUM_SECONDARY=https://rpc.ankr.com/eth
RPC_BSC_PRIMARY=https://bsc-dataseed.binance.org
RPC_POLYGON_PRIMARY=https://polygon-rpc.com
RPC_ARBITRUM_PRIMARY=https://arb1.arbitrum.io/rpc
RPC_OPTIMISM_PRIMARY=https://mainnet.optimism.io
RPC_BASE_PRIMARY=https://mainnet.base.org
